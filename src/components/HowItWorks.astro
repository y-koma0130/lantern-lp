---
const steps = [
	{
		step: "1",
		title: "Pick Your Competitors",
		description:
			"Choose from 30+ pre-built cybersecurity company profiles — or request any company not in the catalog.",
	},
	{
		step: "2",
		title: "AI Monitors & Analyzes",
		description:
			"Lantern scrapes websites, collects G2 reviews, tracks funding, and detects changes automatically every week.",
	},
	{
		step: "3",
		title: "Get Actionable Insights",
		description:
			"Receive scored, categorized insights and auto-generated battle cards delivered to Email, Slack, or Discord.",
	},
];
---

<section class="how-it-works" id="how-it-works">
	<div class="how-inner">
		<div class="section-header">
			<h2 class="section-title">Up and running in minutes</h2>
			<p class="section-subtitle">
				No complex setup. No manual scraping. Just select competitors and let AI do the rest.
			</p>
		</div>
		<div class="steps">
			{steps.map((step) => (
				<div class="step-card">
					<div class="step-number">{step.step}</div>
					<h3 class="step-title">{step.title}</h3>
					<p class="step-desc">{step.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.how-it-works {
		padding: 80px 24px;
		background: var(--surface-subtle);
	}
	.how-inner {
		max-width: 1120px;
		margin: 0 auto;
	}
	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.step-card {
		text-align: center;
		padding: 32px 24px;
	}
	.step-number {
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--brand-primary);
		color: white;
		font-size: 20px;
		font-weight: 700;
		border-radius: 50%;
		margin-bottom: 20px;
	}
	.step-title {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 8px;
	}
	.step-desc {
		font-size: 14px;
		color: var(--text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.steps {
			grid-template-columns: 1fr;
			gap: 16px;
		}
		.how-it-works {
			padding: 56px 24px;
		}
	}
</style>
