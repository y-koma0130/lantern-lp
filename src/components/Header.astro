---
const navLinks = [
	{ label: "Features", href: "#features" },
	{ label: "How It Works", href: "#how-it-works" },
	{ label: "Pricing", href: "#pricing" },
	{ label: "FAQ", href: "#faq" },
];
---

<header class="header">
	<div class="header-inner">
		<a href="/" class="logo">
			<span class="logo-l">l</span><span>antern</span>
		</a>
		<nav class="nav" aria-label="Main navigation">
			{navLinks.map((link) => (
				<a href={link.href} class="nav-link">{link.label}</a>
			))}
		</nav>
		<div class="header-actions">
			<a href="#pricing" class="btn-primary">Get Started Free</a>
		</div>
		<button class="mobile-menu-btn" aria-label="Open menu" id="mobile-menu-btn">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M3 12h18M3 6h18M3 18h18" />
			</svg>
		</button>
	</div>
	<div class="mobile-nav" id="mobile-nav">
		{navLinks.map((link) => (
			<a href={link.href} class="mobile-nav-link">{link.label}</a>
		))}
		<a href="#pricing" class="btn-primary mobile-cta">Get Started Free</a>
	</div>
</header>

<script>
	const btn = document.getElementById("mobile-menu-btn");
	const nav = document.getElementById("mobile-nav");
	btn?.addEventListener("click", () => {
		nav?.classList.toggle("open");
	});
	document.querySelectorAll(".mobile-nav-link, .mobile-cta").forEach((link) => {
		link.addEventListener("click", () => {
			nav?.classList.remove("open");
		});
	});
</script>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
	}
	.header-inner {
		max-width: 1120px;
		margin: 0 auto;
		padding: 0 24px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.logo {
		display: flex;
		align-items: center;
		font-family: var(--font-logo);
		font-weight: 700;
		font-size: 20px;
		color: var(--text-primary);
	}
	.logo-l {
		color: var(--brand-primary);
	}
	.nav {
		display: flex;
		gap: 32px;
	}
	.nav-link {
		font-size: 14px;
		font-weight: 500;
		color: var(--text-secondary);
		transition: color 0.15s;
	}
	.nav-link:hover {
		color: var(--text-primary);
	}
	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 8px 20px;
		background: var(--brand-primary);
		color: white;
		font-size: 14px;
		font-weight: 600;
		border-radius: var(--radius);
		transition: background 0.15s;
	}
	.btn-primary:hover {
		background: var(--brand-hover);
	}
	.mobile-menu-btn {
		display: none;
		color: var(--text-primary);
	}
	.mobile-nav {
		display: none;
	}
	.header-actions {
		display: flex;
	}

	@media (max-width: 768px) {
		.nav,
		.header-actions {
			display: none;
		}
		.mobile-menu-btn {
			display: flex;
		}
		.mobile-nav {
			display: none;
			flex-direction: column;
			padding: 16px 24px;
			border-top: 1px solid var(--border);
			background: var(--surface);
		}
		.mobile-nav.open {
			display: flex;
		}
		.mobile-nav-link {
			padding: 12px 0;
			font-size: 16px;
			font-weight: 500;
			color: var(--text-secondary);
			border-bottom: 1px solid var(--border);
		}
		.mobile-cta {
			margin-top: 16px;
			text-align: center;
			justify-content: center;
		}
	}
</style>
