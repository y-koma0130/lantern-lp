---
const faqs = [
	{
		question: "Which competitors can I track?",
		answer:
			"Lantern ships with 30+ pre-built cybersecurity company profiles covering Cloud Security, Endpoint, AppSec, GRC, IAM, and Threat Intelligence. You can also request any company not in the catalog.",
	},
	{
		question: "What data sources does Lantern monitor?",
		answer:
			"We monitor competitor websites (pricing, features, solutions pages), G2 reviews, Crunchbase (funding & headcount), and Hacker News mentions. AI auto-discovers relevant pages so you don't need to configure URLs manually.",
	},
	{
		question: "How are battle cards generated?",
		answer:
			"Battle cards are generated by AI using the latest competitive data. They include competitor strengths and weaknesses, your differentiation points, and suggested responses to common objections. Available on Pro plans and above.",
	},
	{
		question: "Can I deliver digests to Slack or Discord?",
		answer:
			"Yes. Slack and Discord delivery is available on Starter plans and above. Digests are formatted natively for each platform — Slack Block Kit and Discord Embeds.",
	},
	{
		question: "What does the importance score mean?",
		answer:
			"Every detected change is scored from 1 to 10 based on its potential impact on your sales and positioning. This helps your team focus on the changes that actually matter instead of sifting through noise.",
	},
	{
		question: "Is there a free plan?",
		answer:
			"Yes. The Free plan lets you track up to 3 competitors with monthly email digests. No credit card required. Upgrade anytime to unlock weekly digests, more competitors, and additional features.",
	},
];
---

<section class="faq" id="faq">
	<div class="faq-inner">
		<div class="section-header">
			<h2 class="section-title">Frequently asked questions</h2>
		</div>
		<div class="faq-list">
			{faqs.map((faq) => (
				<details class="faq-item">
					<summary class="faq-question">{faq.question}</summary>
					<p class="faq-answer">{faq.answer}</p>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.faq {
		padding: 80px 24px;
		background: var(--surface-subtle);
	}
	.faq-inner {
		max-width: 720px;
		margin: 0 auto;
	}
	.section-header {
		text-align: center;
		margin-bottom: 48px;
	}
	.section-title {
		font-size: 32px;
		font-weight: 700;
	}
	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.faq-item {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
	}
	.faq-question {
		padding: 20px 24px;
		font-size: 15px;
		font-weight: 600;
		cursor: pointer;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.faq-question::-webkit-details-marker {
		display: none;
	}
	.faq-question::after {
		content: "+";
		font-size: 20px;
		font-weight: 300;
		color: var(--text-tertiary);
		flex-shrink: 0;
		margin-left: 16px;
	}
	.faq-item[open] .faq-question::after {
		content: "\2212";
	}
	.faq-answer {
		padding: 0 24px 20px;
		font-size: 14px;
		color: var(--text-secondary);
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.faq {
			padding: 56px 24px;
		}
	}
</style>
