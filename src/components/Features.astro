---
const features = [
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
		title: "Automated Competitor Monitoring",
		description:
			"AI auto-discovers and scrapes competitor pricing pages, feature pages, and solution pages weekly. No manual setup required.",
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>`,
		title: "AI Change Detection & Scoring",
		description:
			"Detects what changed, scores importance from 1–10, and classifies insights into 6 categories so you focus on what matters.",
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/></svg>`,
		title: "Auto-Generated Battle Cards",
		description:
			"AI creates structured sales battle cards for each competitor — strengths, weaknesses, differentiators, and objection handling.",
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
		title: "G2 Sentiment Analysis",
		description:
			"Collects G2 reviews, analyzes sentiment trends, detects emerging themes, and surfaces sales signals from customer feedback.",
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
		title: "Multi-Channel Delivery",
		description:
			"Get weekly digests delivered where your team already works — Email, Slack, or Discord. No login required to stay informed.",
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
		title: "30+ Cybersecurity Companies",
		description:
			"Pre-built catalog covering Cloud Security, Endpoint, AppSec, GRC, IAM, and more. Just select and go — or request any company.",
	},
];
---

<section class="features" id="features">
	<div class="features-inner">
		<div class="section-header">
			<h2 class="section-title">Everything you need to track competitors</h2>
			<p class="section-subtitle">
				Stop spending hours on manual research. Lantern automates competitive intelligence
				so your team can focus on winning deals.
			</p>
		</div>
		<div class="features-grid">
			{features.map((feature) => (
				<div class="feature-card">
					<div class="feature-icon" set:html={feature.icon} />
					<h3 class="feature-title">{feature.title}</h3>
					<p class="feature-desc">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		padding: 80px 24px;
	}
	.features-inner {
		max-width: 1120px;
		margin: 0 auto;
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	.feature-card {
		padding: 24px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius);
	}
	.feature-icon {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--brand-light);
		color: var(--brand-primary);
		border-radius: var(--radius);
		margin-bottom: 16px;
	}
	.feature-title {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 8px;
	}
	.feature-desc {
		font-size: 14px;
		color: var(--text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
		.features {
			padding: 56px 24px;
		}
	}
</style>
